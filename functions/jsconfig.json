{
    "compilerOptions": {
        "ignoreDeprecations": "6.0",
        "module": "CommonJS",
        "target": "ES2020",
        "moduleResolution": "Node",
        "esModuleInterop": true,
        "allowJs": true,
        "checkJs": false,
        "noEmit": true,
        "skipLibCheck": true,
        "lib": [
            "ES2020"
        ]
    },
    "include": [
        "./**/*.js"
    ],
    "exclude": [
        "node_modules"
    ]
}
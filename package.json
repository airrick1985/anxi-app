{
  "name": "anxi-app",
  "version": "0.0.133",
  "private": true,
  "scripts": {
    "build": "npm run update:manifest-version && npm run generate:release-notes && vue-tsc --noEmit && vite build",
    "deploy": "npm run build && gh-pages -d dist",
    "build-and-deploy": "npm run build && npm run deploy",
    "build-and-push": "npm run build && git add . && git commit -m \"更新 $(TZ='Asia/Taipei' date '+%Y-%m-%d %H:%M:%S')\" && git push",
    "bump-version": "node scripts/bumpVersion.js",
    "dev": "vite",
    "generate:release-notes": "node scripts/generateReleaseNotes.js",
    "preview": "vite preview",
    "update:manifest-version": "node scripts/updateManifestVersion.js"
  },
  "dependencies": {
    "@andy922200/vue-tw-zip-code-selector": "^1.0.1",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/vue-fontawesome": "^3.0.8",
    "@mdi/font": "^7.4.47",
    "@panzoom/panzoom": "^4.6.0",
    "@tiptap/extension-color": "^3.0.7",
    "@tiptap/extension-text-align": "^3.0.7",
    "@tiptap/extension-text-style": "^3.0.7",
    "@tiptap/starter-kit": "^3.0.7",
    "@tiptap/vue-3": "^3.0.7",
    "@vuepic/vue-datepicker": "^11.0.2",
    "@vueuse/core": "^13.1.0",
    "axios": "^1.10.0",
    "fabric": "^5.5.2",
    "file-saver": "^2.0.5",
    "pinia": "^3.0.2",
    "pinia-plugin-persistedstate": "^4.3.0",
    "qrcode": "^1.5.4",
    "qrcode.vue": "^3.6.0",
    "register-service-worker": "^1.7.2",
    "vue": "^3.5.13",
    "vue-axios": "^3.5.2",
    "vue-good-table": "^2.21.11",
    "vue-good-table-next": "^0.2.2",
    "vue-router": "^4.5.0",
    "vue-toastification": "^2.0.0-rc.5",
    "vuetify": "^3.8.2",
    "xlsx": "^0.17.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.2",
    "@vue/cli-plugin-pwa": "~5.0.0",
    "gh-pages": "^6.3.0",
    "vite": "^6.3.1",
    "vite-plugin-pwa": "^1.0.0",
    "vue-tsc": "^2.0.21"
  },
  "homepage": "https://airrick1985.github.io/anxi-app/",
  "type": "module"
}
